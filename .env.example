# =========================
# App
# =========================
APP_NAME="cora-recap-engine"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
API_BASE_URL="http://localhost:8000"
DASHBOARD_BASE_URL="http://localhost:8000/dashboard"
DEFAULT_TIMEZONE=America/Chicago
LOG_LEVEL=INFO
SECRET_KEY=changeme
WEBHOOK_SHARED_SECRET=changeme

# =========================
# Postgres
# =========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DATABASE=cora
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=Target@123
DATABASE_URL=postgresql://postgres:Target@123@localhost:5433/cora

POSTGRES_POOL_SIZE=
POSTGRES_MAX_OVERFLOW=
POSTGRES_ECHO=false

# =========================
# Redis / RQ
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_URL=redis://localhost:6379/0
RQ_DEFAULT_QUEUE=default
RQ_AI_QUEUE=ai
RQ_CALLBACK_QUEUE=callbacks
RQ_RETRY_QUEUE=retries
RQ_SHEET_MIRROR_QUEUE=sheet_mirror
RQ_DASHBOARD_ENABLED=false

# =========================
# GoHighLevel / LeadConnector
# Per-location API key auth
# =========================
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_TIMEOUT_SECONDS=30
GHL_RETRY_MAX=3

# GHL custom fields / mappings
# Labels (human-readable names as configured in GHL)
GHL_FIELD_AI_CAMPAIGN=
GHL_FIELD_AI_CAMPAIGN_VALUE=
GHL_FIELD_AI_LEAD_CLASSIFICATION=
GHL_FIELD_AI_LEAD_ASSIGN_TO=
GHL_FIELD_CALL_DETAILED_SUMMARY=
GHL_FIELD_STUDENT_SUMMARY=

# Unresolved external IDs — must be supplied before write paths are enabled
GHL_FIELD_VM_EMAIL_HTML=
GHL_FIELD_VM_EMAIL_SUBJECT=
GHL_FIELD_VM_SMS_TEXT=
GHL_FIELD_LAST_CALL_STATUS=
GHL_FIELD_MARK_AS_LEAD=
GHL_FIELD_NOTES=
GHL_TASK_PIPELINE_ID=
GHL_TASK_DEFAULT_OWNER_ID=

# =========================
# GHL write/shadow controls
# Default: shadow mode (safe). Change to live only when explicitly approved.
# =========================
GHL_WRITE_MODE=shadow
GHL_WRITE_SHADOW_LOG_ONLY=true
GHL_WRITE_CONTACT_FIELDS=false
GHL_WRITE_NOTES=false
GHL_WRITE_TASKS=false
GHL_WRITE_SUMMARY=false
GHL_WRITE_CAMPAIGN_STATE=false
GHL_WRITE_FINALIZATION=false

# =========================
# Synthflow
# =========================
SYNTHFLOW_BASE_URL=https://api.synthflow.ai/v2/calls
SYNTHFLOW_API_KEY=
SYNTHFLOW_MODEL_ID=
SYNTHFLOW_TIMEOUT_SECONDS=30
SYNTHFLOW_RETRY_MAX=3

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_CALL_ANALYSIS=gpt-4o-mini
OPENAI_MODEL_STUDENT_SUMMARY=gpt-4o-mini
OPENAI_MODEL_CONSENT_DETECTOR=gpt-4o-mini
OPENAI_MODEL_VM_CONTENT=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_RETRY_MAX=3

# Prompt registry defaults
PROMPT_FAMILY_CALL_ANALYSIS=lead_stage_classifier
PROMPT_VERSION_CALL_ANALYSIS=v1
PROMPT_FAMILY_STUDENT_SUMMARY=student_summary_generator
PROMPT_VERSION_STUDENT_SUMMARY=v1
PROMPT_FAMILY_CONSENT=summary_consent_detector
PROMPT_VERSION_CONSENT=v1
PROMPT_FAMILY_VM_CONTENT=vm_content_generator
PROMPT_VERSION_VM_CONTENT=v1

# =========================
# Google Sheets shadow mode
# Unresolved: supply spreadsheet IDs and tab names before enabling Phase 9.
# =========================
GOOGLE_SHADOW_MODE_ENABLED=true
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_CALL_LOG_ID=
GOOGLE_SHEETS_CAMPAIGN_DATA_ID=
GOOGLE_SHEETS_INBOUND_TAB=
GOOGLE_SHEETS_NEW_LEADS_TAB=
GOOGLE_SHEETS_COLD_LEADS_TAB=
GOOGLE_SHEETS_SYNC_INTERVAL_SECONDS=300

# =========================
# Business policy
# =========================
ENABLE_STUDENT_SUMMARY_WRITEBACK=true
SUMMARY_WRITEBACK_REQUIRES_CONSENT=true
TASK_CREATE_ON_COMPLETED_CALL=true
TASK_DUE_DATE_MODE=blank
CANONICAL_TIER_MODEL=None,0,1,2,3
COLD_VM_TIER_NONE_DELAY_MINUTES=120
COLD_VM_TIER_0_DELAY_MINUTES=2880
COLD_VM_TIER_1_DELAY_MINUTES=2880
COLD_VM_TIER_2_FINALIZES=true
# New Lead VM policy — unresolved, must be supplied before New Lead path goes live
NEW_VM_TIER_NONE_DELAY_MINUTES=
NEW_VM_TIER_0_DELAY_MINUTES=
NEW_VM_TIER_1_DELAY_MINUTES=
NEW_VM_TIER_2_FINALIZES=
VM_FINAL_STOP_VALUE=3
SHADOW_MODE_ENABLED=true
# 90-day default: must cover delayed retries, replayed webhooks, shadow-mode
# reconciliation, and re-runs across the full call workflow lifecycle.
IDEMPOTENCY_TTL_DAYS=90
RETENTION_MODE=indefinite

# =========================
# Observability
# =========================
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
METRICS_ENABLED=true
HEALTHCHECK_ENABLED=true
ALERT_WEBHOOK_URL=
